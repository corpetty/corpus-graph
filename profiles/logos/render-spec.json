{
  "version": "0.1.0",
  "description": "Projection for the logos profile. Logos's evidence flows Requirement -evidencedBy-> Document (an OUT-edge from the evidenced node), the opposite of the book/software-docs Source -supports-> Claim model. The 'requirements' section below uses the renderer's `evidenceDirection: \"out\"` option (corpus-graph#7) to surface evidencedBy quotes + line locators. 'contestedClaims'/'editorialFlags' are still omitted: Logos has no supports-vs-pressureTests dialectic to flag.",
  "defaultHop": 2,
  "tokenBudget": 20000,
  "neverRender": ["mentions", "hasStatus", "belongsToTier", "belongsToSubTier", "landsIn", "covers", "narrates"],
  "sections": [
    { "id": "breadcrumb",  "kind": "breadcrumb", "predicates": ["belongsToTier", "belongsToSubTier", "subEntryOf"], "title": null },
    { "id": "summary",     "kind": "centerSummary", "title": null },
    { "id": "requirements","kind": "claimsWithEvidence", "nodeType": "Requirement", "title": "Requirements in scope (with evidence)",
      "evidencePredicates": ["evidencedBy"], "evidenceDirection": "out" },
    { "id": "claims",      "kind": "nodeList", "nodeType": "Claim",      "title": "Claims realised" },
    { "id": "laws",        "kind": "nodeList", "nodeType": "CausalLaw",   "title": "Causal laws it derives from" },
    { "id": "concepts",    "kind": "nodeList", "nodeType": "Concept",     "title": "Concepts" },
    { "id": "adversaries", "kind": "nodeList", "nodeType": "Adversary",   "title": "Adversaries addressed" },
    { "id": "subsystems",  "kind": "nodeList", "nodeType": "Subsystem",   "title": "Realising subsystems" },
    { "id": "families",    "kind": "nodeList", "nodeType": "Family",      "title": "Narrative families" },
    { "id": "tiers",       "kind": "nodeList", "nodeType": "Tier",        "title": "Tiers" },
    { "id": "sections",    "kind": "nodeList", "nodeType": "OutlineSection", "title": "Outline placement" },
    { "id": "sources",     "kind": "sources",  "nodeType": "Source",      "title": "Sources cited" },
    { "id": "tensions",    "kind": "nodeList", "nodeType": "Tension",     "title": "Open tensions" }
  ]
}
